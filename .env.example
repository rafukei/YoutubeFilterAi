# ── App ──────────────────────────────────────────────
APP_NAME=YoutubeFilterAi
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
ALLOWED_ORIGINS=http://localhost:5173,http://localhost

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ytfilter:ytfilter@db:5432/ytfilter

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Admin ────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password

# ── Auth ─────────────────────────────────────────────
ALLOW_GMAIL_AUTH=false
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Telegram (testing) ───────────────────────────────
# Optional: a real bot token for integration tests against Telegram API.
# Create via @BotFather, send /start to the bot, then paste token here.
# Chat ID is fetched automatically via fetch_chat_id().
TEST_TELEGRAM_BOT_TOKEN=

# ── OpenRouter ───────────────────────────────────────
# Each user adds their own token via the UI.
# This controls the free-tier rate limit (requests per minute).
OPENROUTER_FREE_RPM=10
